# ============================================
# ACES Zone Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Database (Required)
DB_SOURCE=postgresql://aces_user:your_secure_password@localhost:5432/aces_zone?sslmode=disable

# Server (Required)
SERVER_ADDRESS=0.0.0.0:8080

# JWT (Required - must be at least 32 characters)
JWT_SECRET=change_this_to_a_random_string_at_least_32_chars

# JWT Token Durations (in minutes)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=10080

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Admin Seeding (Required for seed_admin)
ADMIN_EMAIL=admin@aces.zone
ADMIN_PASSWORD=change_this_to_a_strong_password_min_8_chars

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# File Storage
STORAGE_LOCAL_PATH=./uploads

# Redis
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=

# SMTP Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@aces.zone
SMTP_MOCK=true
